{
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/copyright", "destination": "/copyright.html" },
    { "source": "/cookies", "destination": "/cookies.html" },
    { "source": "/disclaimer", "destination": "/disclaimer.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/careers", "destination": "/careers.html" },
    { "source": "/press", "destination": "/press.html" },
    { "source": "/partners", "destination": "/partners.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/sitemap", "destination": "/sitemap.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/packages", "destination": "/packages.html" },
    { "source": "/products", "destination": "/products.html" },
    { "source": "/protect-app", "destination": "/protect-app.html" }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    },
    {
      "source": "/sitemap.html",
      "headers": [{ "key": "Content-Type", "value": "text/html" }]
    }
  ]
}
